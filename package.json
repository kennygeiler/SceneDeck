{
  "name": "metrovision",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:build": "DATABASE_URL='postgresql://ci:ci@127.0.0.1:5432/ci' NEXT_PUBLIC_SITE_URL='https://metrovision.vercel.app' NODE_OPTIONS=--max-old-space-size=4096 next build",
    "test:worker:build": "pnpm -C worker build && pnpm -C worker typecheck",
    "test:ingest-contracts": "vitest run src/lib/__tests__/ingest-film-stream-contract.test.ts src/lib/__tests__/ingest-film-async-contract.test.ts src/lib/__tests__/worker-http.integration.test.ts",
    "worker:reachability-smoke": "tsx scripts/worker-reachability-smoke.ts",
    "check:schema-drift": "tsx scripts/check-schema-drift.ts",
    "check:taxonomy": "tsx scripts/check-taxonomy-parity.ts",
    "check:worker": "tsc --noEmit -p worker/tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "tsx src/db/seed.ts",
    "db:clear": "tsx scripts/clear-app-data.ts",
    "db:embeddings": "tsx src/db/generate-embeddings.ts",
    "db:embeddings:image": "tsx src/db/generate-image-embeddings.ts",
    "db:studio": "drizzle-kit studio",
    "postinstall": "node scripts/ensure-ffmpeg-static.cjs",
    "batch-worker": "python3 -m pipeline.batch_worker",
    "corpus:ingest": "tsx src/db/ingest-corpus.ts",
    "embeddings:scenes": "tsx src/db/generate-scene-embeddings.ts",
    "eval:export-film": "tsx scripts/export-film-eval.ts",
    "eval:pipeline": "tsx scripts/eval-pipeline.ts",
    "eval:smoke": "tsx scripts/eval-smoke.ts",
    "eval:sweep-tol": "tsx scripts/sweep-eval-tolerance.ts",
    "eval:boundary-deltas": "tsx scripts/eval-boundary-deltas.ts",
    "eval:boundary-misses": "tsx scripts/eval-boundary-misses.ts",
    "eval:sweep-transnet": "tsx scripts/sweep-transnet-threshold.ts",
    "detect:export-cuts": "tsx scripts/detect-export-cuts.ts",
    "detect:refine-fn-windows": "tsx scripts/detect-refine-fn-windows.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@aws-sdk/s3-request-presigner": "^3.1015.0",
    "@base-ui/react": "^1.3.0",
    "@neondatabase/serverless": "^1.0.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@types/d3": "^7.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "drizzle-orm": "^0.45.1",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "next": "15.5.12",
    "openai": "^6.29.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "replicate": "^1.4.0",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "video.js": "^8.23.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
