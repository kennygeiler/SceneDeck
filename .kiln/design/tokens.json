{
  "color": {
    "primitive": {
      "neutral": {
        "50":  { "$type": "color", "$value": "oklch(0.985 0.003 260)", "$description": "Lightest -- cool cream" },
        "100": { "$type": "color", "$value": "oklch(0.960 0.005 260)", "$description": "Light wash" },
        "200": { "$type": "color", "$value": "oklch(0.900 0.008 260)", "$description": "Soft" },
        "300": { "$type": "color", "$value": "oklch(0.800 0.010 260)", "$description": "Muted" },
        "400": { "$type": "color", "$value": "oklch(0.680 0.012 260)", "$description": "Mid" },
        "500": { "$type": "color", "$value": "oklch(0.530 0.014 260)", "$description": "Base" },
        "600": { "$type": "color", "$value": "oklch(0.420 0.014 260)", "$description": "Dark" },
        "700": { "$type": "color", "$value": "oklch(0.330 0.016 260)", "$description": "Darker" },
        "800": { "$type": "color", "$value": "oklch(0.230 0.016 260)", "$description": "Deep" },
        "900": { "$type": "color", "$value": "oklch(0.160 0.012 260)", "$description": "Near-black" },
        "950": { "$type": "color", "$value": "oklch(0.110 0.010 260)", "$description": "Deepest -- cinema dark" }
      },
      "accent": {
        "light":  { "$type": "color", "$value": "oklch(0.820 0.100 200)", "$description": "Light cyan -- projector glow" },
        "base":   { "$type": "color", "$value": "oklch(0.700 0.140 200)", "$description": "Primary cyan -- technical precision" },
        "strong": { "$type": "color", "$value": "oklch(0.560 0.160 200)", "$description": "Strong cyan -- active states" }
      },
      "signal": {
        "amber":  { "$type": "color", "$value": "oklch(0.800 0.160 80)", "$description": "Warm amber -- film warmth, warnings" },
        "red":    { "$type": "color", "$value": "oklch(0.600 0.200 25)", "$description": "Cinematic red -- errors, critical" },
        "green":  { "$type": "color", "$value": "oklch(0.750 0.160 155)", "$description": "Verified green -- success, QA pass" },
        "violet": { "$type": "color", "$value": "oklch(0.650 0.160 300)", "$description": "Violet -- overlay annotations" }
      }
    },
    "semantic": {
      "surface": {
        "primary":   { "$type": "color", "$value": "{color.primitive.neutral.950}", "$description": "Main background -- cinema dark" },
        "secondary": { "$type": "color", "$value": "{color.primitive.neutral.900}", "$description": "Card/panel background" },
        "tertiary":  { "$type": "color", "$value": "{color.primitive.neutral.800}", "$description": "Elevated surface" },
        "inverse":   { "$type": "color", "$value": "{color.primitive.neutral.50}", "$description": "Light surface for contrast" }
      },
      "text": {
        "primary":   { "$type": "color", "$value": "{color.primitive.neutral.50}", "$description": "Primary text -- high contrast" },
        "secondary": { "$type": "color", "$value": "{color.primitive.neutral.400}", "$description": "Secondary text -- metadata labels" },
        "tertiary":  { "$type": "color", "$value": "{color.primitive.neutral.500}", "$description": "Muted text -- timestamps, IDs" },
        "accent":    { "$type": "color", "$value": "{color.primitive.accent.base}", "$description": "Accent text -- links, highlights" }
      },
      "border": {
        "subtle":  { "$type": "color", "$value": "{color.primitive.neutral.800}", "$description": "Subtle divider" },
        "default": { "$type": "color", "$value": "{color.primitive.neutral.700}", "$description": "Standard border" },
        "strong":  { "$type": "color", "$value": "{color.primitive.neutral.600}", "$description": "Emphasized border" }
      },
      "interactive": {
        "default": { "$type": "color", "$value": "{color.primitive.accent.base}", "$description": "Button/link default" },
        "hover":   { "$type": "color", "$value": "{color.primitive.accent.light}", "$description": "Hover state" },
        "active":  { "$type": "color", "$value": "{color.primitive.accent.strong}", "$description": "Active/pressed state" }
      },
      "overlay": {
        "arrow":     { "$type": "color", "$value": "{color.primitive.accent.base}", "$description": "Direction arrows on video" },
        "trajectory": { "$type": "color", "$value": "{color.primitive.signal.violet}", "$description": "Motion path traces" },
        "badge":     { "$type": "color", "$value": "{color.primitive.signal.amber}", "$description": "Movement type badge" },
        "speed":     { "$type": "color", "$value": "{color.primitive.accent.light}", "$description": "Speed indicator" }
      },
      "status": {
        "verified":   { "$type": "color", "$value": "{color.primitive.signal.green}", "$description": "QA verified" },
        "unverified": { "$type": "color", "$value": "{color.primitive.signal.amber}", "$description": "Awaiting verification" },
        "error":      { "$type": "color", "$value": "{color.primitive.signal.red}", "$description": "Error state" }
      }
    }
  },
  "font": {
    "family": {
      "heading": { "$type": "fontFamily", "$value": "var(--font-heading, 'Inter Variable', system-ui, sans-serif)", "$description": "Heading typeface -- geometric precision" },
      "body":    { "$type": "fontFamily", "$value": "var(--font-body, 'Inter Variable', system-ui, sans-serif)", "$description": "Body typeface -- clean readability" },
      "mono":    { "$type": "fontFamily", "$value": "var(--font-mono, 'JetBrains Mono', ui-monospace, monospace)", "$description": "Mono -- timecodes, taxonomy codes, technical data" }
    },
    "size": {
      "xs":   { "$type": "dimension", "$value": "0.75rem",  "$description": "12px -- timecodes, micro labels" },
      "sm":   { "$type": "dimension", "$value": "0.875rem", "$description": "14px -- metadata values, filter labels" },
      "base": { "$type": "dimension", "$value": "1rem",     "$description": "16px -- body text" },
      "lg":   { "$type": "dimension", "$value": "1.125rem", "$description": "18px -- large body, card titles" },
      "xl":   { "$type": "dimension", "$value": "1.25rem",  "$description": "20px -- subheadings" },
      "2xl":  { "$type": "dimension", "$value": "1.5rem",   "$description": "24px -- section headings" },
      "3xl":  { "$type": "dimension", "$value": "2rem",     "$description": "32px -- page titles" },
      "4xl":  { "$type": "dimension", "$value": "2.5rem",   "$description": "40px -- hero subtext" },
      "5xl":  { "$type": "dimension", "$value": "3.5rem",   "$description": "56px -- hero headline" }
    },
    "weight": {
      "normal": { "$type": "fontWeight", "$value": "400", "$description": "Body weight" },
      "medium": { "$type": "fontWeight", "$value": "500", "$description": "Emphasis, labels" },
      "semibold": { "$type": "fontWeight", "$value": "600", "$description": "Subheadings, buttons" },
      "bold":   { "$type": "fontWeight", "$value": "700", "$description": "Headings, hero text" }
    },
    "letterSpacing": {
      "tight":   { "$type": "dimension", "$value": "-0.04em", "$description": "Hero/display text -- cinematic density" },
      "snug":    { "$type": "dimension", "$value": "-0.02em", "$description": "Headings" },
      "normal":  { "$type": "dimension", "$value": "0em",     "$description": "Body text" },
      "wide":    { "$type": "dimension", "$value": "0.08em",  "$description": "All-caps labels -- MOVEMENT TYPE, SPEED" }
    },
    "lineHeight": {
      "tight":  { "$type": "number", "$value": "1.1", "$description": "Headlines" },
      "snug":   { "$type": "number", "$value": "1.3", "$description": "Subheadings" },
      "normal": { "$type": "number", "$value": "1.5", "$description": "Body" },
      "loose":  { "$type": "number", "$value": "1.7", "$description": "Long-form reading" }
    }
  },
  "space": {
    "1":  { "$type": "dimension", "$value": "4px",   "$description": "Tight -- icon gaps" },
    "2":  { "$type": "dimension", "$value": "8px",   "$description": "Compact -- badge padding" },
    "3":  { "$type": "dimension", "$value": "12px",  "$description": "Snug -- input padding" },
    "4":  { "$type": "dimension", "$value": "16px",  "$description": "Base -- card padding" },
    "5":  { "$type": "dimension", "$value": "20px",  "$description": "Comfortable" },
    "6":  { "$type": "dimension", "$value": "24px",  "$description": "Relaxed -- section padding" },
    "8":  { "$type": "dimension", "$value": "32px",  "$description": "Spacious -- grid gaps" },
    "10": { "$type": "dimension", "$value": "40px",  "$description": "Airy" },
    "12": { "$type": "dimension", "$value": "48px",  "$description": "Wide" },
    "16": { "$type": "dimension", "$value": "64px",  "$description": "Expansive -- page margins" },
    "20": { "$type": "dimension", "$value": "80px",  "$description": "Section gap" },
    "24": { "$type": "dimension", "$value": "96px",  "$description": "Major section divider" },
    "32": { "$type": "dimension", "$value": "128px", "$description": "Hero section vertical space" }
  },
  "radius": {
    "sm":   { "$type": "dimension", "$value": "4px",   "$description": "Buttons, inputs, badges" },
    "md":   { "$type": "dimension", "$value": "8px",   "$description": "Cards, panels" },
    "lg":   { "$type": "dimension", "$value": "12px",  "$description": "Modals, overlays" },
    "xl":   { "$type": "dimension", "$value": "16px",  "$description": "Hero sections, feature cards" },
    "full": { "$type": "dimension", "$value": "9999px","$description": "Pills, tags, avatars" }
  },
  "shadow": {
    "sm":  { "$type": "shadow", "$value": "0 1px 2px oklch(0 0 0 / 0.12)", "$description": "Subtle lift" },
    "md":  { "$type": "shadow", "$value": "0 2px 8px oklch(0 0 0 / 0.16), 0 1px 2px oklch(0 0 0 / 0.08)", "$description": "Card shadow" },
    "lg":  { "$type": "shadow", "$value": "0 8px 24px oklch(0 0 0 / 0.20), 0 2px 6px oklch(0 0 0 / 0.10)", "$description": "Dropdown/popover" },
    "xl":  { "$type": "shadow", "$value": "0 16px 48px oklch(0 0 0 / 0.28), 0 4px 12px oklch(0 0 0 / 0.14)", "$description": "Modal overlay -- deeper on dark UI" },
    "glow": { "$type": "shadow", "$value": "0 0 24px oklch(0.700 0.140 200 / 0.25)", "$description": "Accent glow -- hover states, active overlay elements" }
  },
  "opacity": {
    "muted":   { "$type": "number", "$value": "0.3", "$description": "Tertiary/disabled" },
    "medium":  { "$type": "number", "$value": "0.6", "$description": "Secondary content" },
    "full":    { "$type": "number", "$value": "1.0", "$description": "Primary content" }
  }
}
