{
  "name": "metrovision-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node dist/server.mjs",
    "build": "node ../node_modules/esbuild/bin/esbuild src/server.ts --bundle --platform=node --format=esm --packages=external --target=node20 --outfile=dist/server.mjs",
    "typecheck": "node ../node_modules/typescript/bin/tsc --noEmit",
    "dev": "node --import tsx/esm --watch src/server.ts",
    "db:clear": "pnpm -C .. run db:clear"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@aws-sdk/s3-request-presigner": "^3.1015.0",
    "@neondatabase/serverless": "^1.0.2",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.1",
    "esbuild": "^0.25.9",
    "express": "^5.1.0",
    "ffmpeg-static": "^5.3.0",
    "openai": "^6.29.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
